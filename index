<script>
  // Custom cursor - desktop only
  if (window.matchMedia('(hover: hover)').matches) {
    const cursor = document.getElementById('cursor');
    const ring = document.getElementById('cursorRing');
    let mx = -200, my = -200, rx = -200, ry = -200;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
    (function tick() {
      cursor.style.left = mx + 'px'; cursor.style.top = my + 'px';
      rx += (mx - rx) * 0.12; ry += (my - ry) * 0.12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(tick);
    })();
    document.querySelectorAll('button,.product-card').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor.classList.add('hover'); ring.classList.add('hover'); });
      el.addEventListener('mouseleave', () => { cursor.classList.remove('hover'); ring.classList.remove('hover'); });
    });
  }

  // Scroll reveal
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // Order state
  const order = {};

  function changeQty(btn, delta) {
    const card = btn.closest('.product-card');
    const numEl = card.querySelector('.qty-number');
    let val = Math.max(0, parseInt(numEl.textContent) + delta);
    numEl.textContent = val;
    syncCard(card, val);
    updateSummary();
  }

  function toggleItem(btn) {
    const card = btn.closest('.product-card');
    const numEl = card.querySelector('.qty-number');
    let val = parseInt(numEl.textContent) === 0 ? 1 : 0;
    numEl.textContent = val;
    syncCard(card, val);
    updateSummary();
  }

  function syncCard(card, val) {
    const id = card.dataset.id;
    const btn = card.querySelector('.add-btn');
    if (val > 0) {
      order[id] = { name: card.dataset.name, qty: val };
      card.classList.add('selected');
      btn.classList.add('active');
      btn.textContent = 'Added ✓';
    } else {
      delete order[id];
      card.classList.remove('selected');
      btn.classList.remove('active');
      btn.textContent = 'Add to Order';
    }
  }

  function updateSummary() {
    const keys = Object.keys(order);
    const bar = document.getElementById('order-summary');
    if (keys.length === 0) { bar.classList.remove('visible'); return; }
    bar.classList.add('visible');
    document.getElementById('summary-text').textContent =
      keys.map(k => (order[k].name.split('·')[1]?.trim() || order[k].name) + ' ×' + order[k].qty).join(' · ');
  }

  function openModal() {
    if (!Object.keys(order).length) return;
    document.getElementById('order-lines').innerHTML =
      Object.values(order).map(i =>
        `<div class="order-line"><span class="order-line-name">${i.name}</span><span class="order-line-qty">${i.qty} btl.</span></div>`
      ).join('');
    document.getElementById('form-view').style.display = '';
    document.getElementById('success-view').classList.remove('show');
    document.getElementById('modal').classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('active');
    document.body.style.overflow = '';
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  async function submitOrder() {
    const name = document.getElementById('inp-name').value.trim();
    const contact = document.getElementById('inp-contact').value.trim();
    const note = document.getElementById('inp-note').value.trim();
    document.getElementById('inp-name').style.borderColor = name ? 'rgba(201,168,76,0.2)' : '#c0392b';
    document.getElementById('inp-contact').style.borderColor = contact ? 'rgba(201,168,76,0.2)' : '#c0392b';
    if (!name || !contact) return;

    const btn = document.querySelector('.modal-submit');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    const orderList = Object.values(order).map(i => i.name + ' x' + i.qty).join(', ');

    try {
      const res = await fetch('https://formspree.io/f/xeeldldg', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          name: name,
          contact: contact,
          order: orderList,
          note: note || '-',
          _subject: 'NEW PRE-ORDER - Craft4Sense: ' + orderList
        })
      });
      const data = await res.json();
      if (data.ok || res.ok) {
        document.getElementById('form-view').style.display = 'none';
        document.getElementById('success-view').classList.add('show');
      } else {
        btn.textContent = 'Error - try again';
        btn.disabled = false;
      }
    } catch(e) {
      btn.textContent = 'Error - try again';
      btn.disabled = false;
    }
  }
</script>

