<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CRAFT4SENSE - Private Collection</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8D5A3;
    --gold-dark: #8B6914;
    --black: #050505;
    --black-soft: #0E0E0E;
    --white: #F5F0E8;
    --white-dim: rgba(245,240,232,0.6);
  }

- { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
  html { scroll-behavior: smooth; }

body {
background: var(–black);
color: var(–white);
font-family: ‘Cormorant Garamond’, serif;
font-weight: 300;
overflow-x: hidden;
}

body::before {
content: ‘’;
position: fixed; inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘1’/%3E%3C/svg%3E”);
opacity: 0.03; pointer-events: none; z-index: 0;
}

@media (hover: hover) {
body { cursor: none; }
.cursor {
position: fixed; width: 10px; height: 10px;
background: var(–gold); border-radius: 50%;
pointer-events: none; z-index: 9999;
transform: translate(-50%,-50%); mix-blend-mode: screen;
transition: width .3s, height .3s;
}
.cursor-ring {
position: fixed; width: 36px; height: 36px;
border: 1px solid rgba(201,168,76,0.5); border-radius: 50%;
pointer-events: none; z-index: 9998;
transform: translate(-50%,-50%);
transition: width .3s, height .3s, border-color .3s;
}
.cursor.hover { width: 20px; height: 20px; }
.cursor-ring.hover { width: 60px; height: 60px; border-color: var(–gold); }
}
@media (hover: none) { .cursor, .cursor-ring { display: none; } }

/* ─── HERO ─── */
#hero {
position: relative; height: 100svh; min-height: 500px;
display: flex; flex-direction: column;
align-items: center; justify-content: center;
overflow: hidden; padding: 2rem 2rem 4rem; text-align: center;
}
.hero-bg {
position: absolute; inset: 0;
background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201,168,76,0.08) 0%, transparent 70%);
pointer-events: none;
}
.deco-line {
position: absolute;
background: linear-gradient(90deg, transparent, var(–gold), transparent);
height: 1px; width: 70%; left: 15%; opacity: 0.25; pointer-events: none;
}
.deco-line.top { top: 12%; }
.deco-line.bottom { bottom: 12%; }

.hero-eyebrow {
font-family: ‘Cinzel’, serif;
font-size: clamp(0.9rem, 3.2vw, 1.1rem);
letter-spacing: 0.3em; color: var(–gold); margin-bottom: 1.5rem;
opacity: 0; animation: fadeUp 1s ease 0.3s forwards;
}
.hero-title {
font-family: ‘Cinzel’, serif;
font-size: clamp(2.6rem, 11vw, 9rem);
font-weight: 400; letter-spacing: 0.06em; line-height: 1; color: var(–white);
opacity: 0; animation: fadeUp 1.2s ease 0.5s forwards;
}
.hero-subtitle {
font-style: italic;
font-size: clamp(0.88rem, 3vw, 1.4rem);
color: var(–gold-light); margin-top: 1.2rem; letter-spacing: 0.12em;
opacity: 0; animation: fadeUp 1.2s ease 0.8s forwards;
}
.hero-divider {
width: 1px; height: 50px;
background: linear-gradient(180deg, var(–gold), transparent);
margin: 2rem auto 0;
opacity: 0; animation: fadeIn 1s ease 1.2s forwards;
}
.scroll-hint {
font-family: ‘Cinzel’, serif;
font-size: 1rem; letter-spacing: 0.3em; color: var(–gold-dark); margin-top: 0.8rem;
opacity: 0; animation: fadeIn 1s ease 1.5s forwards;
}

/* ─── INTRO ─── */
#intro { max-width: 680px; margin: 0 auto; padding: 8vh 1.5rem 6vh; text-align: center; }
.section-label {
font-family: ‘Cinzel’, serif;
font-size: clamp(0.9rem, 3vw, 1.05rem);
letter-spacing: 0.35em; color: var(–gold); display: block; margin-bottom: 1.5rem;
}
#intro p { font-size: clamp(1.15rem, 4vw, 1.5rem); line-height: 1.9; color: var(–white-dim); }

/* ─── COLLECTION ─── */
#collection { padding: 2vh 0 14vh; max-width: 1400px; margin: 0 auto; }
.collection-header { text-align: center; margin-bottom: 5vh; padding: 0 1.5rem; }
.collection-header h2 {
font-family: ‘Cinzel’, serif;
font-size: clamp(2rem, 6.5vw, 3.2rem); font-weight: 400; letter-spacing: 0.1em; color: var(–white);
}
.gold-rule { width: 60px; height: 1px; background: var(–gold); margin: 1.2rem auto; opacity: 0.6; }

/* ─── GRID ─── */
.products-grid {
display: grid; grid-template-columns: 1fr;
gap: 1px; background: rgba(201,168,76,0.08);
}
@media (min-width: 600px) {
.products-grid { grid-template-columns: repeat(2,1fr); }
.product-card.featured { grid-column: span 2; }
}
@media (min-width: 960px) {
.products-grid { grid-template-columns: repeat(3,1fr); }
.product-card.featured { grid-column: span 3; }
}

/* ─── CARD ─── */
.product-card {
background: var(–black-soft);
padding: clamp(2rem,5vw,3.5rem) clamp(1.2rem,4vw,2.5rem);
display: flex; flex-direction: column; align-items: center; text-align: center;
user-select: none; position: relative; transition: background .4s;
}
.product-card::before {
content: ‘’; position: absolute; inset: 0;
background: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(201,168,76,0.06) 0%, transparent 70%);
opacity: 0; transition: opacity .5s; pointer-events: none;
}
.product-card.selected { background: #111108; }
.product-card.selected::before { opacity: 1; }

.product-age {
font-family: ‘Cinzel’, serif;
font-size: clamp(2.8rem,10vw,5rem); font-weight: 600; color: var(–gold); line-height: 1;
}
.product-age-label {
font-family: ‘Cinzel’, serif;
font-size: clamp(0.9rem,2.8vw,1rem); letter-spacing: 0.3em; color: var(–gold-dark);
margin-top: 0.3rem; display: block;
}
.product-name {
font-size: clamp(1.7rem,5.5vw,2.4rem); font-weight: 300; color: var(–white);
margin: 1.2rem 0 0.6rem; letter-spacing: 0.04em;
}
.product-desc {
font-size: clamp(1.15rem,3.8vw,1.28rem); color: var(–white-dim);
line-height: 1.8; margin-bottom: 1.5rem; font-style: italic; max-width: 340px;
}
.bottle-icon {
width: 1px; height: 45px;
background: linear-gradient(180deg, var(–gold), transparent); margin: 0.5rem auto 0;
}

/* ─── PRICE ─── */
.product-price-block {
margin-top: 1.2rem;
text-align: center;
}
.price-retail {
font-family: ‘Cinzel’, serif;
font-size: clamp(0.95rem, 2.8vw, 1.05rem);
letter-spacing: 0.2em;
color: var(–gold-dark);
text-decoration: line-through;
display: block;
margin-bottom: 0.25rem;
}
.price-preorder {
font-family: ‘Cinzel’, serif;
font-size: clamp(1.5rem, 4.5vw, 1.9rem);
font-weight: 600;
color: var(–gold);
letter-spacing: 0.04em;
display: block;
}
.price-preorder-label {
font-family: ‘Cinzel’, serif;
font-size: clamp(0.88rem, 2.5vw, 0.98rem);
letter-spacing: 0.3em;
color: rgba(201,168,76,0.55);
display: block;
margin-top: 0.2rem;
}

/* ─── QTY ─── */
.qty-control {
display: flex; align-items: stretch; margin-top: 1.8rem;
border: 1px solid rgba(201,168,76,0.3);
}
.qty-btn {
min-width: 52px; height: 52px; background: transparent; color: var(–gold);
font-size: 1.4rem; border: none; display: flex; align-items: center; justify-content: center;
cursor: pointer; touch-action: manipulation; transition: background .2s, color .2s; padding: 0 1rem;
}
.qty-btn:active { background: var(–gold); color: var(–black); }
@media (hover: hover) { .qty-btn:hover { background: var(–gold); color: var(–black); } }

.qty-number {
font-family: ‘Cinzel’, serif; font-size: 1.1rem; color: var(–white);
min-width: 3rem; text-align: center;
border-left: 1px solid rgba(201,168,76,0.2); border-right: 1px solid rgba(201,168,76,0.2);
display: flex; align-items: center; justify-content: center;
}

/* ─── ADD BTN ─── */
.add-btn {
margin-top: 1rem; font-family: ‘Cinzel’, serif;
font-size: clamp(0.95rem,2.8vw,1.05rem); letter-spacing: 0.25em; color: var(–gold);
background: transparent; border: 1px solid rgba(201,168,76,0.3);
padding: 1rem clamp(1rem,4vw,2rem);
cursor: pointer; touch-action: manipulation; width: 100%; max-width: 260px;
transition: background .3s, color .3s, border-color .3s;
}
.add-btn:active, .add-btn.active { background: var(–gold); color: var(–black); border-color: var(–gold); }
@media (hover: hover) { .add-btn:hover { background: var(–gold); color: var(–black); border-color: var(–gold); } }

/* ─── ORDER BAR ─── */
#order-summary {
position: fixed; bottom: 0; left: 0; right: 0;
background: rgba(5,5,5,0.97); border-top: 1px solid rgba(201,168,76,0.25);
padding: 0.9rem 1.2rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem;
transform: translateY(100%); transition: transform .5s cubic-bezier(0.16,1,0.3,1);
z-index: 500; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
}
#order-summary.visible { transform: translateY(0); }
.summary-info { flex: 1; min-width: 0; }
.summary-label {
font-family: ‘Cinzel’, serif; font-size: 0.92rem; letter-spacing: 0.3em; color: var(–gold-dark); display: block;
}
.summary-items {
font-size: 1.15rem; color: var(–white-dim); font-style: italic;
margin-top: 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.submit-btn {
font-family: ‘Cinzel’, serif; font-size: clamp(0.92rem,2.8vw,1rem); letter-spacing: 0.2em;
color: var(–black); background: var(–gold); border: none; padding: 0.9rem 1.4rem;
cursor: pointer; white-space: nowrap; touch-action: manipulation; transition: background .3s; flex-shrink: 0;
}
.submit-btn:active { background: var(–gold-light); }

/* ─── MODAL ─── */
.modal-overlay {
position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 800;
display: flex; align-items: flex-end; justify-content: center;
opacity: 0; pointer-events: none; transition: opacity .4s ease;
}
@media (min-width: 600px) { .modal-overlay { align-items: center; padding: 2rem; } }
.modal-overlay.active { opacity: 1; pointer-events: all; }

.modal {
background: var(–black-soft); border: 1px solid rgba(201,168,76,0.25); border-bottom: none;
padding: 2rem 1.4rem 2rem; width: 100%; max-width: 520px; max-height: 92svh; overflow-y: auto;
position: relative; transform: translateY(40px); transition: transform .5s cubic-bezier(0.16,1,0.3,1);
-webkit-overflow-scrolling: touch;
}
@media (min-width: 600px) { .modal { border-bottom: 1px solid rgba(201,168,76,0.25); padding: 2.8rem 2.2rem; } }
.modal-overlay.active .modal { transform: translateY(0); }

.modal-handle {
width: 40px; height: 3px; background: rgba(201,168,76,0.3); border-radius: 2px;
margin: 0 auto 1.5rem; display: block;
}
@media (min-width: 600px) { .modal-handle { display: none; } }

.modal-close {
position: absolute; top: 1rem; right: 1rem; background: none; border: none;
color: var(–gold-dark); font-size: 1.1rem; cursor: pointer; padding: 0.5rem; touch-action: manipulation;
}
.modal-close:active { color: var(–gold); }

.modal h3 {
font-family: ‘Cinzel’, serif; font-size: clamp(1.1rem,4vw,1.5rem); font-weight: 400;
letter-spacing: 0.1em; color: var(–white); margin-bottom: 0.4rem;
}
.modal-subtitle { font-style: italic; color: var(–gold-light); font-size: 0.95rem; margin-bottom: 1.8rem; display: block; }

.order-lines { border-top: 1px solid rgba(201,168,76,0.15); margin-bottom: 1.8rem; }
.order-line {
display: flex; justify-content: space-between; align-items: center;
padding: 0.75rem 0; border-bottom: 1px solid rgba(201,168,76,0.08); gap: 1rem;
}
.order-line-name { font-size: 0.9rem; color: var(–white-dim); font-style: italic; }
.order-line-qty { font-family: ‘Cinzel’, serif; font-size: 0.8rem; color: var(–gold); white-space: nowrap; }

.form-group { margin-bottom: 1.1rem; }
.form-group label {
font-family: ‘Cinzel’, serif; font-size: 0.9rem; letter-spacing: 0.3em; color: var(–gold-dark);
display: block; margin-bottom: 0.5rem;
}
.form-group input, .form-group textarea {
width: 100%; background: rgba(201,168,76,0.04); border: 1px solid rgba(201,168,76,0.2);
color: var(–white); font-family: ‘Cormorant Garamond’, serif; font-size: 1rem;
padding: 0.8rem 0.9rem; outline: none; transition: border-color .3s; border-radius: 0; -webkit-appearance: none;
}
.form-group input:focus, .form-group textarea:focus { border-color: var(–gold); }
.form-group textarea { height: 70px; resize: none; }
::placeholder { color: rgba(245,240,232,0.2); font-style: italic; }

.modal-submit {
width: 100%; background: var(–gold); color: var(–black); font-family: ‘Cinzel’, serif;
font-size: clamp(0.95rem,2.8vw,1.05rem); letter-spacing: 0.24em; border: none; padding: 1.2rem;
cursor: pointer; touch-action: manipulation; transition: background .3s; margin-top: 0.5rem;
}
.modal-submit:active { background: var(–gold-light); }

.success-view { text-align: center; display: none; }
.success-view.show { display: block; }
.success-icon {
width: 54px; height: 54px; border: 1px solid var(–gold); border-radius: 50%;
display: flex; align-items: center; justify-content: center;
margin: 0 auto 1.5rem; font-size: 1.3rem; color: var(–gold);
}

/* ─── FOOTER ─── */
footer { text-align: center; padding: 5vh 1.5rem 10vh; border-top: 1px solid rgba(201,168,76,0.08); }
footer p { font-family: ‘Cinzel’, serif; font-size: clamp(0.38rem,1.8vw,0.55rem); letter-spacing: 0.32em; color: rgba(201,168,76,0.3); }

/* ─── ANIMATIONS ─── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }
</style>

</head>
