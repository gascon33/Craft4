<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>The Jeweler by Jacob&Co — Private Allocation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{background:#050505;color:#FFFFFF;font-family:'Cinzel',serif;font-weight:400;overflow-x:hidden;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;-webkit-text-size-adjust:100%}

/* TOP WATERMARK */
#top-watermark{position:fixed;top:0;left:0;right:0;z-index:999;text-align:center;padding:0.45rem 1rem;pointer-events:none}
#top-watermark span{font-family:'Cinzel',serif;font-size:clamp(0.55rem,1.5vw,0.7rem);letter-spacing:0.3em;color:#E6C48F;opacity:0.45}

/* GATE */
#gate{position:fixed;inset:0;z-index:100;background:#050505;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:3rem 2rem;transition:opacity 1.2s ease}
#gate.out{opacity:0;pointer-events:none}
.g-rule{position:absolute;left:8vw;right:8vw;height:1px;background:linear-gradient(90deg,transparent,#E6C48F44,transparent)}
.g-rule.t{top:10vh}
.g-rule.b{bottom:10vh}
.g-eyebrow{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.34em;color:#E6C48F;line-height:2.2;margin-bottom:2.5rem;opacity:0;animation:up 1s ease 0.2s forwards}
.g-brand{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(2rem,8vw,5rem);letter-spacing:0.06em;color:#F7ECDB;line-height:1.1;white-space:nowrap;margin-bottom:0.4rem;opacity:0;animation:up 1.2s ease 0.45s forwards}
.g-subbrand{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(1.2rem,4vw,2.4rem);letter-spacing:0.18em;color:#E6C48F;margin-bottom:0;opacity:0;animation:up 1s ease 0.7s forwards}
.g-div{width:1px;height:40px;background:linear-gradient(180deg,#E6C48F,transparent);margin:2.5rem auto;opacity:0;animation:fi 1s ease 1s forwards}
.g-wlabel{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.4em;color:#E6C48F;margin-bottom:0.5rem;opacity:0;animation:fi 1s ease 1.2s forwards}
.g-wdate{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.22em;color:#E6C48F;margin-bottom:3rem;opacity:0;animation:fi 1s ease 1.4s forwards}
.g-pw-label{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);letter-spacing:0.3em;color:#E6C48F;opacity:0.7;margin-bottom:0.6rem;display:block;opacity:0;animation:fi 1s ease 1.5s forwards}
.g-pw-wrap{display:flex;gap:0;margin-bottom:2rem;opacity:0;animation:fi 1s ease 1.55s forwards}
.g-pw-input{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.25em;background:#E6C48F10;border:1px solid #E6C48F44;border-right:none;color:#FFFFFF;padding:0.9rem 1.2rem;outline:none;width:220px;border-radius:0;-webkit-appearance:none;transition:border-color .3s}
.g-pw-input:focus{border-color:#E6C48F}
.g-pw-input::placeholder{color:#E6C48F33}
.g-enter{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.35em;background:#F7ECDB;color:#050505;border:none;padding:0.9rem 1.6rem;cursor:pointer;-webkit-appearance:none;border-radius:0;display:block;transition:opacity .3s}
.g-enter:active{opacity:0.8}
.g-pw-err{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.75rem);letter-spacing:0.2em;color:#c0392b;margin-top:0.4rem;opacity:0;transition:opacity .3s;min-height:1.2em}
.g-pw-err.show{opacity:1}

/* MAIN */
#main{opacity:0;transition:opacity 1.2s ease}
#main.show{opacity:1}

/* STATUS */
#status{padding:14vh 2rem 10vh;text-align:center;max-width:640px;margin:0 auto}
.lbl{font-family:'Cinzel',serif;font-size:clamp(0.9rem,2.8vw,1.1rem);letter-spacing:0.4em;color:#E6C48F;display:block}
.s-line{width:1px;height:50px;background:linear-gradient(180deg,transparent,#E6C48F,transparent);margin:2.5rem auto}
.s-text{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);line-height:2.6;color:#FFFFFF;letter-spacing:0.14em}
.s-text em{color:#E6C48F;font-style:normal}

/* COLLECTION */
#collection{padding:4vh 0 16vh;max-width:1300px;margin:0 auto}
.col-header{text-align:center;padding:0 2rem 8vh}
.col-brand{font-family:'Cormorant Garamond',serif;font-weight:400;line-height:1.1;letter-spacing:0.03em;color:#F7ECDB;display:block}
.col-jacobco{font-size:clamp(2rem,6vw,3.5rem);margin-bottom:0.2rem}
.col-craft{font-size:clamp(1.2rem,3.5vw,2rem);margin-bottom:1.5rem;letter-spacing:0.18em;color:#E6C48F}
.col-title{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.17em;color:#FFFFFF}
.g-rule-h{width:36px;height:1px;background:linear-gradient(90deg,#8B6914,#E8D5A3,#8B6914);margin:1.5rem auto;opacity:0.7}

/* GRID */
.grid{display:grid;grid-template-columns:1fr;gap:1px;background:#E6C48F12}
@media(min-width:700px){.grid{grid-template-columns:repeat(2,1fr)}}

/* CARD */
.card{background:#0C0C0C;padding:clamp(2.5rem,5vw,4rem) clamp(1.5rem,4vw,3rem);display:flex;flex-direction:column;align-items:center;text-align:center;transition:background .5s}
.card.open{background:#0f0f08}
.c-brand{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(1.4rem,4.5vw,2.2rem);line-height:1.2;letter-spacing:0.05em;color:#F7ECDB;margin-bottom:0.3rem;display:block}
.c-num{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(2rem,7vw,3rem);line-height:1;color:#E6C48F}
.c-age-lbl{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.3em;color:#E6C48F;margin-top:0.5rem;display:block}
.c-sub{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.2em;color:#E6C48F;margin:0.6rem 0 0.4rem}
.c-name{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.13em;color:#FFFFFF;margin:0.8rem 0 2rem}
.c-table{width:100%;border-top:1px solid #E6C48F22;padding-top:1.4rem;margin-bottom:1.6rem}
.c-row{display:flex;justify-content:space-between;align-items:baseline;padding:0.5rem 0;border-bottom:1px solid #E6C48F12;gap:0.5rem}
.c-lbl{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.16em;color:#E6C48F;white-space:nowrap;flex-shrink:0}
.c-val{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);color:#FFFFFF;text-align:right}
.c-price-block{text-align:center;margin-bottom:2rem}
.c-price-lbl{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.8rem);letter-spacing:0.3em;color:#E6C48F;opacity:.6;display:block;margin-bottom:0.8rem}
.c-price{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(2rem,7vw,3rem);color:#F7ECDB;display:block;line-height:1}
.c-req{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.28em;padding:0.85rem 1rem;width:100%;display:block;text-align:center;border:1px solid #E6C48F;color:#E6C48F;background:transparent;cursor:pointer;-webkit-appearance:none;border-radius:0;touch-action:manipulation;transition:background .3s,color .3s}
.c-req:active,.c-req:hover{background:#E6C48F;color:#050505}
.c-exp{width:100%;overflow:hidden;max-height:0;transition:max-height .65s cubic-bezier(.16,1,.3,1),opacity .4s;opacity:0}
.c-exp.open{max-height:800px;opacity:1}
.c-exp-inner{border-top:1px solid #E6C48F20;margin-top:2rem;padding-top:2rem}
.qty-row{display:flex;align-items:center;justify-content:center;border:1px solid #E6C48F44;margin-bottom:1rem}
.qty-btn{width:48px;height:48px;background:transparent;color:#E6C48F;font-size:1.3rem;border:none;cursor:pointer;touch-action:manipulation;transition:background .2s,color .2s}
.qty-btn:active{background:#E6C48F;color:#050505}
.qty-n{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);color:#FFFFFF;min-width:3rem;text-align:center;border-left:1px solid #E6C48F33;border-right:1px solid #E6C48F33;height:48px;display:flex;align-items:center;justify-content:center}
.c-add{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:.3em;color:#050505;background:#E6C48F;border:none;padding:.9rem;cursor:pointer;width:100%;touch-action:manipulation;transition:opacity .3s;margin-top:.2rem;-webkit-appearance:none;border-radius:0}
.c-add:active,.c-add.done{opacity:.6}

/* ORDER BAR */
#bar{position:fixed;bottom:0;left:0;right:0;background:#050505FA;border-top:1px solid #E6C48F33;padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;transform:translateY(100%);transition:transform .6s cubic-bezier(.16,1,.3,1);z-index:200;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
#bar.show{transform:translateY(0)}
.bar-info{flex:1;min-width:0}
.bar-lbl{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);letter-spacing:.35em;color:#E6C48F;display:block}
.bar-txt{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);color:#FFFFFF;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:.2rem}
.bar-btn{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);letter-spacing:.28em;color:#050505;background:#E6C48F;border:none;padding:.85rem 1.3rem;cursor:pointer;white-space:nowrap;touch-action:manipulation;-webkit-appearance:none;border-radius:0;flex-shrink:0}
.bar-btn:active{opacity:.8}

/* MODAL */
.m-ov{position:fixed;inset:0;background:#000000EE;z-index:800;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .4s}
.m-ov.open{opacity:1;pointer-events:all}
@media(min-width:600px){.m-ov{align-items:center;padding:2rem}}
.modal{background:#0C0C0C;border:1px solid #E6C48F33;border-bottom:none;padding:2rem 1.5rem;width:100%;max-width:520px;max-height:92svh;overflow-y:auto;position:relative;transform:translateY(30px);transition:transform .5s cubic-bezier(.16,1,.3,1);-webkit-overflow-scrolling:touch}
.m-ov.open .modal{transform:translateY(0)}
@media(min-width:600px){.modal{border-bottom:1px solid #E6C48F33;padding:3rem 2.5rem}}
.m-handle{width:36px;height:3px;background:#E6C48F33;border-radius:2px;margin:0 auto 2rem;display:block}
@media(min-width:600px){.m-handle{display:none}}
.m-close{position:absolute;top:1rem;right:1rem;background:none;border:none;color:#E6C48F;font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);letter-spacing:.15em;cursor:pointer;padding:.5rem}
.m-brand{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:.3em;color:#F7ECDB;display:block;margin-bottom:.3rem}
.m-title{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:0.15em;color:#FFFFFF;margin-bottom:.3rem}
.m-sub{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);color:#E6C48F;opacity:.6;letter-spacing:.15em;margin-bottom:2rem;display:block}
.m-lines{border-top:1px solid #E6C48F20;margin-bottom:1.5rem}
.m-line{display:flex;justify-content:space-between;align-items:baseline;padding:.65rem 0;border-bottom:1px solid #E6C48F12;gap:1rem}
.m-line-n{font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);color:#FFFFFF;letter-spacing:.1em}
.m-line-q{font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);color:#E6C48F;white-space:nowrap}
.m-terms{border:1px solid #E6C48F22;padding:1.2rem 1.4rem;margin-bottom:1.8rem}
.m-terms p{font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);color:#FFFFFF;opacity:.7;line-height:1.9;letter-spacing:.08em}
.m-terms p+p{margin-top:.4rem}
.f-group{margin-bottom:1rem}
.f-group label{font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);letter-spacing:.3em;color:#E6C48F;display:block;margin-bottom:.5rem}
.f-group input,.f-group textarea{width:100%;background:#E6C48F08;border:1px solid #E6C48F2A;color:#FFFFFF;font-family:'Cinzel',serif;font-size:clamp(0.7rem,2.2vw,0.85rem);padding:.82rem .9rem;outline:none;transition:border-color .3s;border-radius:0;-webkit-appearance:none}
.f-group input:focus,.f-group textarea:focus{border-color:#E6C48F}
.f-group input.err{border-color:#c0392b}
.f-group textarea{height:70px;resize:none}
::placeholder{color:#E6C48F44}
.m-submit{width:100%;background:#E6C48F;color:#050505;font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);letter-spacing:.3em;border:none;padding:1.1rem;cursor:pointer;-webkit-appearance:none;border-radius:0;touch-action:manipulation;transition:opacity .3s;margin-top:.5rem}
.m-submit:active{opacity:.8}
.m-submit:disabled{opacity:.5}
.m-success{text-align:center;display:none}
.m-success.show{display:block}
.m-check{font-size:1.2rem;color:#E6C48F;width:48px;height:48px;border:1px solid #E6C48F;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.8rem}

/* CONF + FOOTER */
#conf{border-top:1px solid #E6C48F12;padding:8vh 2rem 10vh;text-align:center;max-width:580px;margin:0 auto}
.conf-txt{font-family:'Cinzel',serif;font-size:clamp(0.75rem,2.5vw,0.95rem);color:#FFFFFF;opacity:.7;line-height:2.3;letter-spacing:.1em}
.conf-div{width:28px;height:1px;background:#E6C48F;margin:2.5rem auto;opacity:.3}
footer{text-align:center;padding:0 2rem 6vh}
footer p{font-family:'Cinzel',serif;font-size:clamp(0.65rem,2vw,0.78rem);letter-spacing:.3em;color:#E6C48F;opacity:.2}

/* ANIMATIONS */
@keyframes up{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes fi{from{opacity:0}to{opacity:1}}
.rev{opacity:0;transform:translateY(20px);transition:opacity .8s ease,transform .8s ease}
.rev.on{opacity:1;transform:translateY(0)}
</style>
</head>
<body>

<!-- TOP WATERMARK (all pages) -->
<div id="top-watermark">
  <span>Craft4Sense</span>
</div>

<!-- GATE -->
<div id="gate">
  <div class="g-rule t"></div>
  <div class="g-rule b"></div>
  <p class="g-eyebrow">BY APPOINTMENT ONLY<br>STRICTLY LIMITED QUANTITY</p>
  <h1 class="g-brand">The Jeweler by Jacob&amp;Co</h1>
  <p class="g-subbrand">Cognac Grande Champagne</p>
  <div class="g-div"></div>
  <p class="g-pw-label" style="animation-fill-mode:forwards">ENTER YOUR PASSWORD</p>
  <div class="g-pw-wrap">
    <input class="g-pw-input" type="password" id="g-pw" placeholder="· · · · · · · ·" onkeydown="if(event.key==='Enter')enter()">
    <button class="g-enter" onclick="enter()">ENTER</button>
  </div>
  <p class="g-pw-err" id="g-pw-err">Incorrect password</p>
</div>

<!-- MAIN -->
<div id="main">

  <section id="status">
    <span class="lbl rev">PRIVATE ALLOCATION ONLY</span>
    <div class="s-line rev"></div>
    <p class="s-text rev">
      This collection is available<br>
      by <em>private allocation only.</em><br>
      Each release is strictly limited.<br>
      Allocation is reviewed individually.
    </p>
  </section>

  <section id="collection">
    <div class="col-header rev">
      <span class="col-brand col-jacobco">The Jeweler by Jacob &amp; Co</span>
      <span class="col-brand col-craft">Cognac Grande Champagne</span>
      <h2 class="col-title">Private Collection</h2>
      <div class="g-rule-h"></div>
    </div>
    <div class="grid">

      <!-- CARD 1 — 60 YEARS -->
      <div class="card rev" data-id="1" data-name="Cognac · Diamond Reserve 1965" data-price="10000">
        <span class="c-brand">The Jeweler by Jacob &amp; Co</span>
        <span class="c-num">60</span>
        <span class="c-age-lbl">YEARS OF AGEING</span>
        <span class="c-sub">100% COGNAC GRAND CHAMPAGNE</span>
        <h3 class="c-name">Diamond Reserve 1965</h3>
        <div class="c-table">
          <div class="c-row"><span class="c-lbl">VINTAGE</span><span class="c-val">1965</span></div>
          <div class="c-row"><span class="c-lbl">DEDICATED TO</span><span class="c-val">Jacob Arabo, born 1965</span></div>
          <div class="c-row"><span class="c-lbl">APPELLATION</span><span class="c-val">Cognac Grand Champagne</span></div>
          <div class="c-row"><span class="c-lbl">MATURATION</span><span class="c-val">60 years and more, Limousin oak</span></div>
          <div class="c-row"><span class="c-lbl">TOTAL PRODUCTION</span><span class="c-val">1,000 bottles</span></div>
          <div class="c-row"><span class="c-lbl">BOTTLE NUMBERING</span><span class="c-val">001 — 1000</span></div>
        </div>
        <div class="c-price-block">
          <span class="c-price-lbl">PRICE PER BOTTLE</span>
          <span class="c-price">EUR 10,000</span>
        </div>
        <button class="c-req" onclick="toggleCard(this)">REQUEST ALLOCATION</button>
        <div class="c-exp">
          <div class="c-exp-inner">
            <div class="qty-row">
              <button class="qty-btn" onclick="chQty(this,-1)">−</button>
              <span class="qty-n">1</span>
              <button class="qty-btn" onclick="chQty(this,1)">+</button>
            </div>
            <button class="c-add" onclick="addOrder(this)">ADD TO ALLOCATION REQUEST</button>
          </div>
        </div>
      </div>

      <!-- CARD 2 — 100 YEARS -->
      <div class="card rev" data-id="2" data-name="Cognac · Century Reserve" data-price="25000">
        <span class="c-brand">The Jeweler by Jacob &amp; Co</span>
        <span class="c-num">100</span>
        <span class="c-age-lbl">YEARS OF AGEING</span>
        <span class="c-sub">100% COGNAC GRAND CHAMPAGNE</span>
        <h3 class="c-name">Century Reserve</h3>
        <div class="c-table">
          <div class="c-row"><span class="c-lbl">VINTAGE</span><span class="c-val">1924</span></div>
          <div class="c-row"><span class="c-lbl">DEDICATED TO</span><span class="c-val">The Art of Time</span></div>
          <div class="c-row"><span class="c-lbl">APPELLATION</span><span class="c-val">Cognac Grand Champagne</span></div>
          <div class="c-row"><span class="c-lbl">MATURATION</span><span class="c-val">100 years and more, Limousin oak</span></div>
          <div class="c-row"><span class="c-lbl">TOTAL PRODUCTION</span><span class="c-val">500 bottles</span></div>
          <div class="c-row"><span class="c-lbl">BOTTLE NUMBERING</span><span class="c-val">001 — 500</span></div>
        </div>
        <div class="c-price-block">
          <span class="c-price-lbl">PRICE PER BOTTLE</span>
          <span class="c-price">EUR 25,000</span>
        </div>
        <button class="c-req" onclick="toggleCard(this)">REQUEST ALLOCATION</button>
        <div class="c-exp">
          <div class="c-exp-inner">
            <div class="qty-row">
              <button class="qty-btn" onclick="chQty(this,-1)">−</button>
              <span class="qty-n">1</span>
              <button class="qty-btn" onclick="chQty(this,1)">+</button>
            </div>
            <button class="c-add" onclick="addOrder(this)">ADD TO ALLOCATION REQUEST</button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="conf" class="rev">
    <span class="lbl" style="margin-bottom:2rem">CONFIDENTIALITY</span>
    <p class="conf-txt">All allocations are handled privately.<br>Client identities remain strictly confidential.<br>No public registry of ownership is maintained.</p>
    <div class="conf-div"></div>
  </section>

  <footer>
    <p>CRAFT4SENSE · PRIVATE COLLECTION · THE JEWELER BY JACOB &amp; CO</p>
    <p style="margin-top:0.8rem">BY INVITATION ONLY</p>
  </footer>

</div>

<!-- ORDER BAR -->
<div id="bar">
  <div class="bar-info">
    <span class="bar-lbl">ALLOCATION REQUEST</span>
    <p class="bar-txt" id="bar-txt">-</p>
  </div>
  <button class="bar-btn" onclick="openModal()">SUBMIT REQUEST</button>
</div>

<!-- MODAL -->
<div class="m-ov" id="modal">
  <div class="modal">
    <span class="m-handle"></span>
    <button class="m-close" onclick="closeModal()">CLOSE</button>
    <div id="m-form">
      <span class="m-brand">THE JEWELER BY JACOB &amp; CO</span>
      <h3 class="m-title">Private Allocation Request</h3>
      <span class="m-sub">Craft4Sense · Private Collection</span>
      <div class="m-lines" id="m-lines"></div>
      <div class="m-terms">
        <p>Prices are exclusive of VAT. VAT is determined by the country of the recipient and is payable separately upon delivery.</p>
        <p>Delivery is included in the price.</p>
        <p>Payment details will be communicated upon allocation confirmation.</p>
      </div>
      <div class="f-group"><label>FIRST &amp; LAST NAME *</label><input type="text" id="f-name" placeholder="First and Last Name" autocomplete="name"></div>
      <div class="f-group"><label>PHONE *</label><input type="tel" id="f-phone" placeholder="+1 (000) 000-0000" autocomplete="tel"></div>
      <div class="f-group"><label>EMAIL *</label><input type="email" id="f-email" placeholder="your@email.com" autocomplete="email"></div>
      <div class="f-group"><label>NOTE</label><textarea id="f-note" placeholder="Any additional requests..."></textarea></div>
      <button class="m-submit" onclick="submitOrder()">CONFIRM ALLOCATION REQUEST</button>
    </div>
    <div class="m-success" id="m-success">
      <div class="m-check">✓</div>
      <h3 class="m-title">Private Allocation Request Received</h3>
      <span class="m-sub">A client liaison will contact you directly.</span>
    </div>
  </div>
</div>

<script>
var PASS = 'jacob2026';

function enter() {
  var pw = document.getElementById('g-pw').value;
  var err = document.getElementById('g-pw-err');
  if(pw !== PASS){ err.classList.add('show'); document.getElementById('g-pw').classList.add('err')||null; return; }
  err.classList.remove('show');
  var g = document.getElementById('gate');
  var m = document.getElementById('main');
  g.classList.add('out');
  setTimeout(function(){ g.style.display='none'; m.classList.add('show'); }, 1200);
}

var obs = new IntersectionObserver(function(entries){
  entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('on'); obs.unobserve(e.target); } });
}, { threshold: 0.08 });

document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('.rev').forEach(function(el){ obs.observe(el); });
  document.getElementById('modal').addEventListener('click', function(e){ if(e.target===this) closeModal(); });
});

function toggleCard(btn) {
  var card = btn.closest('.card');
  var exp = card.querySelector('.c-exp');
  var isOpen = exp.classList.contains('open');
  document.querySelectorAll('.c-exp.open').forEach(function(e){ e.classList.remove('open'); });
  document.querySelectorAll('.card.open').forEach(function(c){ c.classList.remove('open'); });
  document.querySelectorAll('.c-req').forEach(function(b){ b.textContent='REQUEST ALLOCATION'; });
  if(!isOpen){
    exp.classList.add('open'); card.classList.add('open'); btn.textContent='CLOSE';
    setTimeout(function(){ card.scrollIntoView({behavior:'smooth',block:'nearest'}); }, 150);
  }
}

function chQty(btn, d) {
  var n = btn.closest('.qty-row').querySelector('.qty-n');
  n.textContent = Math.max(1, parseInt(n.textContent) + d);
}

var order = {};

function addOrder(btn) {
  var card = btn.closest('.card');
  var id = card.dataset.id;
  var qty = parseInt(card.querySelector('.qty-n').textContent);
  order[id] = { name: card.dataset.name, qty: qty, price: parseFloat(card.dataset.price) };
  btn.textContent = 'ADDED'; btn.classList.add('done');
  updateBar();
}

function updateBar() {
  var keys = Object.keys(order);
  var bar = document.getElementById('bar');
  if(!keys.length){ bar.classList.remove('show'); return; }
  bar.classList.add('show');
  var total = keys.reduce(function(s,k){ return s+order[k].price*order[k].qty; }, 0);
  document.getElementById('bar-txt').textContent = keys.map(function(k){
    var p = order[k].name.split('·'); return (p[1]||order[k].name).trim()+' x'+order[k].qty;
  }).join(' · ')+' | EUR '+total.toLocaleString('en-US');
}

function openModal() {
  if(!Object.keys(order).length) return;
  var total = Object.keys(order).reduce(function(s,k){ return s+order[k].price*order[k].qty; }, 0);
  var lines = Object.values(order).map(function(i){
    return '<div class="m-line"><span class="m-line-n">'+i.name+'</span><span class="m-line-q">'+i.qty+' btl / EUR '+(i.price*i.qty).toLocaleString('en-US')+'</span></div>';
  }).join('');
  document.getElementById('m-lines').innerHTML = lines+
    '<div class="m-line" style="border-top:1px solid rgba(230,196,143,.2);margin-top:.5rem;padding-top:.7rem">'+
    '<span class="m-line-n" style="letter-spacing:.1em">TOTAL</span>'+
    '<span class="m-line-q" style="font-size:1.1rem">EUR '+total.toLocaleString('en-US')+'</span></div>';
  document.getElementById('m-form').style.display='';
  document.getElementById('m-success').classList.remove('show');
  document.getElementById('modal').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeModal() {
  document.getElementById('modal').classList.remove('open');
  document.body.style.overflow='';
}

function submitOrder() {
  var name = document.getElementById('f-name').value.trim();
  var phone = document.getElementById('f-phone').value.trim();
  var email = document.getElementById('f-email').value.trim();
  var note = document.getElementById('f-note').value.trim();
  var ok = true;
  ['f-name','f-phone','f-email'].forEach(function(id){
    var el = document.getElementById(id);
    var v = el.value.trim()!=='';
    el.classList.toggle('err',!v); if(!v) ok=false;
  });
  if(email.indexOf('@')<1){ ok=false; document.getElementById('f-email').classList.add('err'); }
  if(!ok) return;
  var btn = document.querySelector('.m-submit');
  btn.textContent='Sending...'; btn.disabled=true;
  var total = Object.keys(order).reduce(function(s,k){ return s+order[k].price*order[k].qty; }, 0);
  var ol = Object.values(order).map(function(i){ return i.name+' x'+i.qty+' (EUR '+(i.price*i.qty).toLocaleString('en-US')+')'; }).join(', ');
  fetch('/api/send',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({name:name,phone:phone,email:email,order:ol,total:'EUR '+total.toLocaleString('en-US'),note:note||'-'})
  }).then(function(r){
    if(r.ok){ document.getElementById('m-form').style.display='none'; document.getElementById('m-success').classList.add('show'); }
    else{ btn.textContent='Error - try again'; btn.disabled=false; }
  }).catch(function(){ btn.textContent='Error - try again'; btn.disabled=false; });
}
</script>

</body>
</html>
